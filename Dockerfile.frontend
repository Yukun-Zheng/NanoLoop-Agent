# syntax=docker/dockerfile:1

ARG PYTHON_VERSION=3.12

FROM python:${PYTHON_VERSION}-slim-bookworm AS builder

ENV PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /build

COPY pyproject.toml README.md LICENSES.md ./
COPY app ./app

RUN python -m pip wheel --wheel-dir /wheels '.[frontend]'


FROM python:${PYTHON_VERSION}-slim-bookworm AS runtime

ARG APP_UID=10001
ARG APP_GID=10001

LABEL org.opencontainers.image.title="NanoLoop Agent Frontend" \
      org.opencontainers.image.description="REST-only Streamlit scientific workbench" \
      org.opencontainers.image.licenses="LicenseRef-Proprietary"

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1 \
    HOME=/tmp \
    STREAMLIT_SERVER_HEADLESS=true \
    STREAMLIT_SERVER_ADDRESS=0.0.0.0 \
    STREAMLIT_SERVER_PORT=8501 \
    STREAMLIT_BROWSER_GATHER_USAGE_STATS=false \
    NANOLOOP_API_BASE_URL=http://api:8000

RUN groupadd --gid "${APP_GID}" nanoloop \
    && useradd --uid "${APP_UID}" --gid "${APP_GID}" \
        --create-home --home-dir /home/nanoloop --shell /usr/sbin/nologin nanoloop \
    && mkdir -p /app/frontend \
    && chown -R nanoloop:nanoloop /app /home/nanoloop

WORKDIR /app

COPY --from=builder /wheels /wheels
RUN python -m pip install --no-index --find-links=/wheels nanoloop-agent streamlit \
    && rm -rf /wheels

COPY --chown=nanoloop:nanoloop frontend ./frontend

USER nanoloop:nanoloop

EXPOSE 8501
STOPSIGNAL SIGTERM

HEALTHCHECK --interval=15s --timeout=5s --start-period=15s --retries=5 \
    CMD ["python", "-c", "import urllib.request; assert urllib.request.urlopen('http://127.0.0.1:8501/_stcore/health',timeout=3).read().strip() == b'ok'"]

CMD ["streamlit", "run", "frontend/app.py"]
