.DS_Store
.env
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
dist/
build/

# Runtime state and generated scientific artifacts
data/*.db
data/*.db-*
data/.file_token_secret
data/.file_token_v2_keyring.json
data/model-snapshots/
outputs/*
!outputs/.gitkeep
knowledge_base/index/*
!knowledge_base/index/.gitkeep
knowledge_base/sources/*
!knowledge_base/sources/.gitkeep
model_artifacts/weights/*
!model_artifacts/weights/.gitkeep

# RAG acceptance private inputs and generated evidence
rag-acceptance-v1/corpus/sources/*
!rag-acceptance-v1/corpus/sources/.gitkeep
rag-acceptance-v1/evaluation/*-results.*
rag-acceptance-v1/evaluation/acceptance-summary.*
rag-acceptance-v1/index-evidence/*.faiss
rag-acceptance-v1/index-evidence/*.index
rag-acceptance-v1/index-evidence/index-sha256.txt
rag-acceptance-v1/index-evidence/database-membership-summary.json
rag-acceptance-v1/run-record/*.json

# Frontend/runtime caches
.streamlit/secrets.toml
node_modules/
