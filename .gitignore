.DS_Store
.env
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
dist/
build/

# Runtime state and generated scientific artifacts
data/*.db
data/*.db-*
data/.file_token_secret
data/.file_token_v2_keyring.json
data/model-snapshots/
outputs/*
!outputs/.gitkeep
knowledge_base/index/*
!knowledge_base/index/.gitkeep
knowledge_base/sources/*
!knowledge_base/sources/.gitkeep
model_artifacts/weights/*
!model_artifacts/weights/.gitkeep
!model_artifacts/weights/unet-large-optimized-v1.pt

# RAG acceptance: default-deny private inputs and generated evidence.  Only the
# explicitly listed public contracts/examples may be tracked below.
rag-acceptance-v1/corpus/sources/*
!rag-acceptance-v1/corpus/sources/.gitkeep
rag-acceptance-v1/embedding/*
!rag-acceptance-v1/embedding/model-manifest.json
rag-acceptance-v1/evaluation/*
!rag-acceptance-v1/evaluation/judgment-schema.json
!rag-acceptance-v1/evaluation/questions.jsonl
rag-acceptance-v1/index-evidence/*
!rag-acceptance-v1/index-evidence/generation-manifest.example.json
rag-acceptance-v1/run-record/*
!rag-acceptance-v1/run-record/commands.txt.example
!rag-acceptance-v1/run-record/environment.txt.example

# Frontend/runtime caches
.streamlit/secrets.toml
node_modules/
data/.nanoloop-state.lock
