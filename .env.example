APP_ENV=development
DATABASE_URL=sqlite:///./data/nanoloop.db
OUTPUT_ROOT=./outputs
# Stable file-token v2 signing key ring. Keep this regular file at mode 0600 inside data_root.
# The production container initializes the missing default through the protected key-ring store.
FILE_TOKEN_V2_KEYRING_PATH=./data/.file_token_v2_keyring.json
MODEL_REGISTRY_PATH=./model_artifacts/registry.yaml
MODEL_SNAPSHOT_ROOT=./data/model-snapshots
MODEL_DEVICE=auto
# Compose only: complete host bundle containing registry.yaml, configs/, model_cards/,
# weights/, and any custom adapter sources. It is mounted at /app/model_artifacts read-only.
NANOLOOP_MODEL_ARTIFACTS_DIR=./model_artifacts
KNOWLEDGE_SOURCE_DIR=./knowledge_base/sources
FAISS_INDEX_PATH=./knowledge_base/index/faiss.index
# Runtime is local-files-only. Prefer replacing this ID with an absolute verified snapshot directory.
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
# Immutable upstream revision used by scripts/prepare_embedding_snapshot.py.
EMBEDDING_MODEL_REVISION=13942ee7a1615d20a84b41e800c63775e174f97f
KNOWLEDGE_MAX_PDF_PAGES=2000
KNOWLEDGE_MAX_EXTRACTED_CHARS=10000000
KNOWLEDGE_MAX_CHUNKS_PER_DOCUMENT=20000
KNOWLEDGE_MAX_VECTOR_INDEX_CHUNKS=100000
EMBEDDING_INDEX_BATCH_SIZE=128
# Keep FAISS at one OpenMP thread by default. This is deterministic and avoids
# PyTorch/FAISS native-runtime crashes observed on supported macOS arm64 hosts.
FAISS_THREAD_COUNT=1
DATA_DISTRIBUTION_EVIDENCE_LIMIT=200
# Docker Compose defaults to the local Ollama Qwen model below. These Compose-only
# names intentionally do not reuse LLM_PROVIDER/LLM_MODEL, so an older local .env
# cannot silently force the container back to extractive mode.
NANOLOOP_COMPOSE_LLM_PROVIDER=openai_compatible
NANOLOOP_COMPOSE_LLM_BASE_URL=http://host.docker.internal:11434/v1
NANOLOOP_COMPOSE_LLM_API_KEY=ollama
NANOLOOP_COMPOSE_LLM_MODEL=qwen3:4b-instruct-2507-q4_K_M
# Set NANOLOOP_COMPOSE_LLM_PROVIDER=extractive only for an explicit no-Qwen run.

# Direct Python development settings:
LLM_PROVIDER=extractive
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
# Direct Python with host Ollama:
# LLM_PROVIDER=openai_compatible
# LLM_BASE_URL=http://127.0.0.1:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=<exact installed Qwen3 tag from `ollama list`>
LLM_TIMEOUT_SECONDS=90
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0
LLM_HISTORY_TURNS=8
# Hard character ceiling applied after the turn ceiling.
LLM_HISTORY_MAX_CHARS=12000
MAX_UPLOAD_MB=200
MAX_REQUEST_MB=512
ANALYSIS_WORKER_COUNT=2
ANALYSIS_QUEUE_CAPACITY=32
ANALYSIS_SCHEDULER_POLL_SECONDS=0.5
SHUTDOWN_TIMEOUT_SECONDS=30
LOG_LEVEL=INFO
# Comma-separated Host-header allowlist. Add the deployed API hostname explicitly.
TRUSTED_HOSTS=localhost,127.0.0.1,testserver,api
# Comma-separated HTTP(S) origins allowed to issue browser mutation requests.
CORS_ALLOW_ORIGINS=
# Authentication mode: auto preserves the legacy behavior (shared_key when a key is set,
# otherwise disabled). Explicit principal mode never falls back to the shared key.
AUTH_MODE=auto
# Optional single shared service key. Generate with:
# python -c 'import secrets; print(secrets.token_urlsafe(32))'
# Required only for shared_key mode. It may carry a principal token to the Next.js server-side
# BFF, but the API never treats it as a shared-key fallback while AUTH_MODE=principal.
# Never expose this value through NEXT_PUBLIC_*.
NANOLOOP_API_KEY=
# Required for principal mode; use independent random 32+ byte secret material and keep it stable.
# python -c 'import secrets; print(secrets.token_urlsafe(48))'
CREDENTIAL_PEPPER=
# One fixed token bucket per authentication class; 0 disables the in-process limiter.
# In principal mode this becomes the authenticated per-principal bucket.
API_RATE_LIMIT_REQUESTS=120
API_RATE_LIMIT_WINDOW_SECONDS=60
# Principal mode only: higher-capacity pre-authentication bucket per direct socket peer.
# Forwarded and X-Forwarded-For headers are intentionally ignored and bundled Uvicorn commands
# disable proxy-header rewriting. Set 0 to delegate this stage to a trusted ingress. Multiple API
# workers or replicas do not share in-process limits.
API_PRINCIPAL_PREAUTH_RATE_LIMIT_REQUESTS=600
API_PRINCIPAL_PREAUTH_RATE_LIMIT_WINDOW_SECONDS=60
# Strict maximum retained keys for each in-process keyed limiter.
API_RATE_LIMIT_MAX_BUCKETS=4096
# CLI/smoke clients use this public backend URL.
NANOLOOP_API_BASE_URL=http://localhost:8000
# Next.js server-only upstream. The browser always calls same-origin /api/nanoloop/*.
NANOLOOP_API_INTERNAL_URL=http://127.0.0.1:8000
# Exact comma-separated origins accepted by the Next.js BFF. Set the deployed HTTPS
# origin explicitly; this also rejects hostile Host/DNS-rebinding requests.
NANOLOOP_FRONTEND_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
# Host port published by Compose; the frontend container always listens on 3000.
NANOLOOP_FRONTEND_PORT=3000
NANOLOOP_BIND_HOST=127.0.0.1

# Optional image build profile after local assets are mounted: rag, models, or rag,models.
NANOLOOP_API_EXTRAS=
# Optional container-build package index. Keep the official default unless the
# deployment environment provides a trusted, synchronized organizational mirror.
PYPI_INDEX_URL=https://pypi.org/simple

# Required for stable download links in non-container production. Generate a random 32+ byte value.
NANOLOOP_FILE_TOKEN_SECRET=
