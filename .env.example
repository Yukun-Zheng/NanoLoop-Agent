APP_ENV=development
DATABASE_URL=sqlite:///./data/nanoloop.db
OUTPUT_ROOT=./outputs
MODEL_REGISTRY_PATH=./model_artifacts/registry.yaml
MODEL_SNAPSHOT_ROOT=./data/model-snapshots
MODEL_DEVICE=auto
# Compose only: complete host bundle containing registry.yaml, configs/, model_cards/,
# weights/, and any custom adapter sources. It is mounted at /app/model_artifacts read-only.
NANOLOOP_MODEL_ARTIFACTS_DIR=./model_artifacts
KNOWLEDGE_SOURCE_DIR=./knowledge_base/sources
FAISS_INDEX_PATH=./knowledge_base/index/faiss.index
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
# Required for a Hub model: pin the exact 40-64 character commit digest.
# A local EMBEDDING_MODEL directory is fingerprinted directly and needs no revision.
EMBEDDING_MODEL_REVISION=
KNOWLEDGE_MAX_PDF_PAGES=2000
KNOWLEDGE_MAX_EXTRACTED_CHARS=10000000
KNOWLEDGE_MAX_CHUNKS_PER_DOCUMENT=20000
KNOWLEDGE_MAX_VECTOR_INDEX_CHUNKS=100000
EMBEDDING_INDEX_BATCH_SIZE=128
DATA_DISTRIBUTION_EVIDENCE_LIMIT=200
LLM_PROVIDER=extractive
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
MAX_UPLOAD_MB=200
MAX_REQUEST_MB=512
ANALYSIS_WORKER_COUNT=2
ANALYSIS_QUEUE_CAPACITY=32
ANALYSIS_SCHEDULER_POLL_SECONDS=0.5
SHUTDOWN_TIMEOUT_SECONDS=30
LOG_LEVEL=INFO
# Comma-separated Host-header allowlist. Add the deployed API hostname explicitly.
TRUSTED_HOSTS=localhost,127.0.0.1,testserver,api
# Comma-separated HTTP(S) origins allowed to issue browser mutation requests.
CORS_ALLOW_ORIGINS=
# Authentication mode: auto preserves the legacy behavior (shared_key when a key is set,
# otherwise disabled). Explicit principal mode never falls back to the shared key.
AUTH_MODE=auto
# Optional single shared service key. Generate with:
# python -c 'import secrets; print(secrets.token_urlsafe(32))'
# Required only for shared_key mode. It may carry a principal token to the unchanged frontend,
# but the API never treats it as a shared-key fallback while AUTH_MODE=principal.
NANOLOOP_API_KEY=
# Required for principal mode; use independent random 32+ byte secret material and keep it stable.
# python -c 'import secrets; print(secrets.token_urlsafe(48))'
CREDENTIAL_PEPPER=
# One fixed token bucket per authentication class; 0 disables the in-process limiter.
# In principal mode this becomes the authenticated per-principal bucket.
API_RATE_LIMIT_REQUESTS=120
API_RATE_LIMIT_WINDOW_SECONDS=60
# Principal mode only: higher-capacity pre-authentication bucket per direct socket peer.
# Forwarded and X-Forwarded-For headers are intentionally ignored and bundled Uvicorn commands
# disable proxy-header rewriting. Set 0 to delegate this stage to a trusted ingress. Multiple API
# workers or replicas do not share in-process limits.
API_PRINCIPAL_PREAUTH_RATE_LIMIT_REQUESTS=600
API_PRINCIPAL_PREAUTH_RATE_LIMIT_WINDOW_SECONDS=60
# Strict maximum retained keys for each in-process keyed limiter.
API_RATE_LIMIT_MAX_BUCKETS=4096
NANOLOOP_API_BASE_URL=http://localhost:8000
NANOLOOP_BIND_HOST=127.0.0.1

# Optional image build profile after local assets are mounted: rag, models, or rag,models.
NANOLOOP_API_EXTRAS=

# Required for stable download links in non-container production. Generate a random 32+ byte value.
NANOLOOP_FILE_TOKEN_SECRET=
