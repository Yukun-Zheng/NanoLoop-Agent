{
  "name": "@nanoloop/command-center",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.34.5",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=10 <11"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "generate:api": "openapi-typescript ../docs/api/openapi-v1.json -o src/lib/api/schema.d.ts",
    "check:api": "pnpm generate:api && git diff --exit-code -- src/lib/api/schema.d.ts",
    "audit:prod": "pnpm audit --prod",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "check": "pnpm audit:prod && pnpm check:api && pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "@hookform/resolvers": "5.4.0",
    "@radix-ui/react-dialog": "1.1.21",
    "@radix-ui/react-slot": "1.3.1",
    "@radix-ui/react-tabs": "1.1.19",
    "@radix-ui/react-tooltip": "1.2.14",
    "@tanstack/react-query": "5.101.4",
    "clsx": "2.1.1",
    "konva": "10.3.0",
    "lucide-react": "1.26.0",
    "next": "16.2.11",
    "openapi-fetch": "0.17.0",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "react-hook-form": "7.82.0",
    "react-konva": "19.2.5",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.3",
    "@testing-library/jest-dom": "7.0.0",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.4",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.11",
    "jsdom": "29.1.1",
    "openapi-typescript": "7.13.0",
    "tailwindcss": "4.3.3",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.22",
      "sharp": "0.35.0"
    }
  }
}
